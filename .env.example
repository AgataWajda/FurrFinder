# -----------------------------------------------------------------------------
# FURRFINDER - ENVIRONMENT VARIABLES TEMPLATE
# Instructions: Copy this file to .env and fill in your actual credentials.
# WARNING: Never commit the actual .env file to version control (Git).
# -----------------------------------------------------------------------------

# --- FIREBASE CONFIGURATION (Web SDK) ---
# Locate these in: Firebase Console -> Project Settings -> General -> Your Apps
EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=furrfinder-xxxx.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=furrfinder-xxxx
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=furrfinder-xxxx.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef123456
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
